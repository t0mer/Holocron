# Compiled class file
*.class

# Log file
*.log

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files #
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# virtual machine crash logs, see http://www.java.com/en/download/help/error_hotspot.xml
hs_err_pid*
replay_pid*

# Kotlin Gradle plugin data, see https://kotlinlang.org/docs/whatsnew20.html#new-directory-for-kotlin-data-in-gradle-projects
.kotlin/

# Claude / AI assistant context — local only, never track
CLAUDE.md
.claude/
.cursor/
.aider*

# Design / implementation / planning docs — local only
/docs/
docs/*
*.design.md
*.implementation.md

# Android / Gradle build output
.gradle/
build/
/build/
app/build/
local.properties
captures/
*.apk
*.aab
*.ap_
*.dex

# Signing material — never commit
*.jks
*.keystore
*.jks.base64
keystore.properties

# IDE / OS
.idea/
.vscode/
*.iml
*.swp
.DS_Store

# Keep the Gradle wrapper jar tracked despite the *.jar rule above
!gradle/wrapper/gradle-wrapper.jar